---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';

const projectList = await getCollection('projects'); // Fetch the new collection
const projects = projectList.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section id="projects" class="py-24 max-w-6xl mx-auto px-6">
  <p class="text-xs font-mono text-blue-500 uppercase tracking-widest mb-2">Work</p>
  <h2 class="text-4xl font-bold text-white mb-12">Featured <span class="text-cyan-400">Projects</span></h2>

      <!-- <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"> --> 
       <div class="flex flex-col gap-16"></div>
        {projects.map((project) => (
          <ProjectCard project={project.data} />
        ))}
      </div>
</section>