---
const navItems = [
  { name: 'Skills', href: '#skills' },
  { name: 'Experience', href: '#experience' },
  { name: 'Projects', href: '#projects' },
  { name: 'Contact', href: 'mailto:arifhasan.mbstu@gmail.com' }, // Update with your email
];
---

<nav class="fixed top-0 w-full z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-900">
  <div class="max-w-6xl mx-auto px-6 h-16 flex justify-between items-center">
    
    <a href="/" class="text-white font-bold text-xl tracking-tighter hover:text-blue-400 transition-colors">
      AH<span class="text-blue-500">.</span>
    </a>

    <div class="hidden md:flex gap-8">
      {navItems.map(item => (
        <a href={item.href} class="text-sm font-medium text-slate-400 hover:text-white transition-colors">
          {item.name}
        </a>
      ))}
    </div>

    <button id="menu-toggle" class="md:hidden text-slate-400 hover:text-white" aria-label="Toggle Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-slate-950 border-b border-slate-900 px-6 py-4 space-y-4">
    {navItems.map(item => (
      <a href={item.href} class="block text-slate-400 hover:text-white text-lg">
        {item.name}
      </a>
    ))}
  </div>
</nav>

<script>
  // Simple JS to handle the mobile toggle
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close menu when a link is clicked
  const links = menu?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>