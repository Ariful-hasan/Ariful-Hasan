---
const navItems = [
  { name: 'Skills', href: '#skills' },
  { name: 'Experience', href: '#experience' },
  { name: 'Projects', href: '#projects' },
  { name: 'Contact', href: 'mailto:arifhasan.mbstu@gmail.com' },
];

const base = '/Ariful-Hasan'; 
---

<nav class="fixed top-0 w-full z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-900">
  <div class="max-w-6xl mx-auto px-6 h-16 flex justify-between items-center">
    
    <a href={`${base}/`} class="text-white font-bold text-xl tracking-tighter hover:text-blue-400 transition-colors">
      AH<span class="text-blue-500">.</span>
    </a>

    <div class="hidden md:flex items-center gap-8 ml-auto">
      {navItems.map(item => (
        <a href={item.href} class="text-sm font-medium text-slate-400 hover:text-white transition-colors">
          {item.name}
        </a>
      ))}

      <div class="relative group py-2">
        <button class="text-slate-400 group-hover:text-blue-400 transition-colors font-medium text-sm flex items-center gap-1">
          CV
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-180 transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div class="absolute right-0 mt-2 w-36 bg-slate-900 border border-slate-800 rounded-lg shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="p-1 flex flex-col">
            <a href={`${base}/cv-ariful-hasan-en.pdf`} download class="px-4 py-2 text-xs font-medium text-slate-300 hover:bg-blue-500/10 hover:text-blue-400 rounded-md transition-all">English (EN)</a>
            <a href={`${base}/cv-ariful-hasan-de.pdf`} download class="px-4 py-2 text-xs font-medium text-slate-300 hover:bg-blue-500/10 hover:text-blue-400 rounded-md transition-all">Deutsch (DE)</a>
          </div>
        </div>
      </div>
    </div>

    <button id="menu-toggle" class="md:hidden text-slate-400 hover:text-white" aria-label="Toggle Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-slate-950 border-b border-slate-900 px-6 py-6 space-y-4">
    {navItems.map(item => (
      <a href={item.href} class="block text-slate-400 hover:text-white text-lg">
        {item.name}
      </a>
    ))}
    <div class="pt-4 border-t border-slate-900">
      <p class="text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-3 font-bold">Download CV</p>
      <div class="flex gap-4 items-center">
        <a href={`${base}/cv-ariful-hasan-en.pdf`} download class="text-blue-400 font-medium">English</a>
        <div class="w-px h-4 bg-slate-800"></div>
        <a href={`${base}/cv-ariful-hasan-de.pdf`} download class="text-blue-400 font-medium">Deutsch</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const links = menu?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>