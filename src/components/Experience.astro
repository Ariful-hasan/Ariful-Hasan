---
import { getCollection } from 'astro:content';
const jobs = await getCollection('experience');
const sortedJobs = jobs.sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
---

<section id="experience" class="py-24 max-w-5xl mx-auto px-6">
  <p class="text-xs font-mono text-blue-500 uppercase tracking-widest mb-2">Career</p>
  <h2 class="text-4xl font-bold text-white mb-12">Work <span class="text-cyan-400">Experience</span></h2>

  <div class="relative space-y-8 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-800 before:to-transparent">
    
    {sortedJobs.map((job) => (
      <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
        <div class="flex items-center justify-center w-10 h-10 rounded-full border border-slate-800 bg-[#0f172a] text-blue-400 shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2">
          <svg class="fill-current" viewBox="0 0 16 16" width="16" height="16"><path d="M8 0a8 8 0 1 0 8 8 8.009 8.009 0 0 0-8-8Zm0 14a6 6 0 1 1 6-6 6.007 6.007 0 0 1-6 6Z"/><path d="M11 7H5a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1Z"/></svg>
        </div>

        <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-[#0f172a]/50 border border-slate-800 p-6 rounded-xl hover:border-slate-700 transition-colors shadow-xl">
          <div class="flex items-center justify-between space-x-2 mb-1">
            <h3 class="font-bold text-white">{job.data.role}</h3>
            <time class="font-mono text-xs text-slate-500 italic">
              {job.data.startDate.getFullYear()} – {job.data.endDate ? job.data.endDate.getFullYear() : 'Present'}
            </time>
          </div>
          <div class="text-blue-400 text-sm font-medium mb-3">{job.data.company}</div>
          <div class="text-slate-400 text-sm leading-relaxed">{job.data.description}</div>
          
          <ul class="mt-4 space-y-2">
             {job.data.achievements.map(task => (
               <li class="text-xs text-slate-400 flex gap-2">
                <span class="text-blue-500">•</span> {task}
              </li>
             ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>