---
import { Image } from 'astro:assets';
const { project } = Astro.props;

// Dynamically find the image in your assets folder
// const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif}');
// if (!images[project.imagePath]) throw new Error(`"${project.imagePath}" not found.`);
---

<div class="group mb-6 bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all duration-300">
  <!-- <div class="aspect-video overflow-hidden border-b border-slate-800">
    <Image 
      src={images[project.imagePath]()} 
      alt={project.title}
      width={800}
      height={450}
      class="object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div> -->
  
  <div class="p-6">
    <h3 class="text-xl font-bold text-white mb-2">{project.title}</h3>
    <p class="text-slate-400 text-sm mb-4 line-clamp-2">{project.description}</p>
    
    <div class="flex flex-wrap gap-2 mb-6">
      {project.tags.map((tag) => (
        <span class="px-2 py-1 bg-slate-800 text-blue-400 text-xs font-mono rounded">{tag}</span>
      ))}
    </div>
    
    <a href={project.link} target="_blank" class="text-white text-sm font-medium flex items-center gap-2 hover:text-blue-400 transition-colors">
      View Source 
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
  </div>
</div>